CREATE OR REPLACE FILE FORMAT stream_csv_format
    TYPE = CSV
    COMPRESSION = AUTO
    FIELD_DELIMITER = ','
    SKIP_HEADER = 1
    FIELD_OPTIONALLY_ENCLOSED_BY = '"'
    NULL_IF = ('\\N', 'NULL', 'null', '')
    EMPTY_FIELD_AS_NULL = TRUE
    ERROR_ON_COLUMN_COUNT_MISMATCH = FALSE -- Crucial for streaming resilient pipelines
    REPLACE_INVALID_CHARACTERS = TRUE;

CREATE OR REPLACE FILE FORMAT stream_json_format
    TYPE = JSON
    COMPRESSION = AUTO
    STRIP_OUTER_ARRAY = TRUE -- Essential if your stream sends batches as [ {..}, {..} ]
    ENABLE_OCTAL = FALSE
    ALLOW_DUPLICATE = FALSE
    STRIP_NULL_VALUES = FALSE
    IGNORE_UTF8_ERRORS = TRUE;


CREATE OR REPLACE FILE FORMAT stream_avro_format
    TYPE = AVRO
    COMPRESSION = AUTO
    REPLACE_INVALID_CHARACTERS = TRUE;


CREATE OR REPLACE FILE FORMAT stream_orc_format
    TYPE = ORC
    TRIM_SPACE = TRUE
    REPLACE_INVALID_CHARACTERS = TRUE;


CREATE OR REPLACE FILE FORMAT stream_parquet_format
    TYPE = PARQUET
    COMPRESSION = AUTO
    BINARY_AS_TEXT = FALSE -- Prevents Snowflake from forcing binary data into text strings
    TRIM_SPACE = TRUE
    REPLACE_INVALID_CHARACTERS = TRUE;


CREATE OR REPLACE FILE FORMAT stream_xml_format
    TYPE = XML
    COMPRESSION = AUTO
    STRIP_OUTER_ELEMENT = TRUE -- Removes the root tag so repeating child tags become rows
    PRESERVE_SPACE = FALSE
    IGNORE_UTF8_ERRORS = TRUE;
